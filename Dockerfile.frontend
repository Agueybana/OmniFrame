# Dev-only image: runs the Vite dev server with hot reload.
# Source is bind-mounted at runtime (see docker-compose.yml); the
# node_modules installed here stay in the image because the compose file
# only mounts individual source paths, not the repo root.
FROM node:22-alpine

WORKDIR /app
COPY package*.json ./
RUN npm ci

CMD ["npm", "run", "dev:frontend"]
